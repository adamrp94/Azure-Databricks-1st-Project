   "source": [
    "CREATE OR REPLACE TABLE sales_by_month AS\n",
    "SELECT\n",
    "  d.year,\n",
    "  d.month,\n",
    "  MAKE_DATE(d.year, d.month, 1) AS date,\n",
    "  SUM(f.l_extendedprice * (1 - f.l_discount)) AS total_sales\n",
    "FROM fact_orders f\n",
    "JOIN dim_date d\n",
    "  ON f.l_shipdate = d.date\n",
    "GROUP BY d.year, d.month\n",
    "ORDER BY d.year, d.month;\n",
    "\n"
   ]
  }
 ],
